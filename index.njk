---
layout: layout.njk
title: "Jalur Tumbuh — BK SMP Al Hikmah Surabaya"
---
<header>
  <nav class="wrap">
    <div class="brand">
      <img src="/css/uploads/logo-bk.png" alt="Logo BK SMP Al Hikmah" class="brand-logo">
      Jalur Tumbuh — SMP Al Hikmah Surabaya
    </div>
    <div class="navlinks">
      <a href="#profil">Tim BK</a>
      <a href="#materi">Materi Klasikal</a>
      <a href="#berita">Berita</a>
      <a href="#sosmed">Media Sosial</a>
      <a href="#info">Konsultasi</a>
    </div>
  </nav>
</header>

<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow">{{ site.hero_eyebrow }}</span>
      <h1>{{ site.hero_judul_1 }} <em>{{ site.hero_judul_2 }}</em></h1>
      <p class="lede">{{ site.hero_deskripsi }}</p>
      <div class="hero-ctas">
        <a href="#materi" class="btn btn-primary">{{ site.hero_tombol_1 }}</a>
        <a href="#profil" class="btn btn-ghost">{{ site.hero_tombol_2 }}</a>
      </div>

      <div class="ayat-box">
        <div class="ayat-arab">{{ site.ayat_arab }}</div>
        <div class="ayat-arti">{{ site.ayat_arti }}</div>
        <span class="ayat-sumber">{{ site.ayat_sumber }}</span>
      </div>
    </div>
    <div class="pathwrap">
      <svg viewBox="0 0 360 320" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M30 280 C 90 280, 70 200, 130 190 S 200 120, 180 90 S 260 40, 330 40"
              fill="none" stroke="#1F4F4A" stroke-width="2.5" stroke-dasharray="6 8" opacity="0.5"/>
        <circle class="step-dot" cx="30" cy="280" r="7"/>
        <circle class="step-dot" cx="130" cy="190" r="7"/>
        <circle class="step-dot" cx="180" cy="90" r="7"/>
        <circle class="step-dot" cx="330" cy="40" r="9"/>
        <text class="step-label" x="44" y="284">Kenali diri</text>
        <text class="step-label" x="144" y="194">Tumbuh bersama</text>
        <text class="step-label" x="100" y="78">Temukan arah</text>
        <text class="step-label" x="270" y="30">Raih cita-cita</text>
      </svg>
    </div>
  </div>
</section>

<hr class="div">

<section id="profil">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.profil_eyebrow }}</span>
      <h2>{{ site.profil_judul }}</h2>
      <p>{{ site.profil_deskripsi }}</p>
    </div>
    <div class="tim-grid">
      {% for orang in collections.profil %}
      <div class="tim-card">
        {% if orang.data.foto %}
        <img src="{{ orang.data.foto }}" alt="{{ orang.data.nama }}" class="tim-avatar tim-avatar-photo">
        {% else %}
        <div class="tim-avatar">{{ orang.data.inisial }}</div>
        {% endif %}
        <h3>{{ orang.data.nama }}</h3>
        <div class="tim-role">Guru BK — SMP Al Hikmah Surabaya</div>
        <a class="tim-wa" href="https://wa.me/62{{ orang.data.whatsapp | replace('0','',1) }}" target="_blank" rel="noopener">💬 WhatsApp</a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section id="materi">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.materi_eyebrow }}</span>
      <h2>{{ site.materi_judul }}</h2>
      <p>{{ site.materi_deskripsi }}</p>
    </div>
    <div class="materi-grid">
      {% for m in collections.materi %}
      <div class="card">
        <span class="num">{{ m.data.num }}</span>
        <h3>{{ m.data.title }}</h3>
        <p>{{ m.data.ringkasan }}</p>
        {% if m.data.links and m.data.links.length %}
        <div class="link-list">
          {% for l in m.data.links %}
          <a href="{{ l.url }}" target="_blank" rel="noopener"><i class="link-ic">↗</i>{{ l.label }}</a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section id="berita">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.berita_eyebrow }}</span>
      <h2>{{ site.berita_judul }}</h2>
    </div>
    <div class="berita-list">
      {% for b in collections.berita %}
      <div class="berita-item">
        <div class="berita-tanggal">{{ b.data.tanggal }}</div>
        <div>
          <div class="berita-judul">{{ b.data.judul }}</div>
          <div class="berita-ringkasan">{{ b.data.ringkasan }}</div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section id="sosmed">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">{{ site.sosmed_eyebrow }}</span>
      <h2>{{ site.sosmed_judul }}</h2>
    </div>
    <div class="sosmed-grid">
      <a class="sos-card sos-ig" href="https://instagram.com/insightgram.cons" target="_blank" rel="noopener">
        <div class="sos-top"><span class="sos-icon">📷</span></div>
        <div>
          <div class="sos-name">Instagram</div>
          <div class="sos-note">@insightgram.cons</div>
        </div>
      </a>
      <a class="sos-card sos-em" href="mailto:bk.smp.alhikmahsby@gmail.com">
        <div class="sos-top"><span class="sos-icon">✉️</span></div>
        <div>
          <div class="sos-name">Email</div>
          <div class="sos-note">bk.smp.alhikmahsby@gmail.com</div>
        </div>
      </a>
    </div>

    {% if collections.video.length %}
    <div class="video-section">
      <h3 class="video-heading"><span class="sos-icon">▶</span> {{ site.video_heading }}</h3>
      <div class="video-list">
        {% for v in collections.video %}
        <a class="video-item" href="{{ v.data.youtube_url }}" target="_blank" rel="noopener">
          <span class="video-judul">{{ v.data.judul }}</span>
          {% for m in collections.materi %}
            {% if m.data.num == v.data.materi_terkait %}
            <span class="video-tag">Materi {{ m.data.num }} — {{ m.data.title }}</span>
            {% endif %}
          {% endfor %}
        </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
</section>

<section id="info">
  <div class="wrap">
    <div class="info-box">
      <span class="eyebrow" style="color:var(--marigold);">{{ site.info_eyebrow }}</span>
      <h3>{{ site.info_judul }}</h3>
      <p>{{ site.info_deskripsi }}</p>

      <div class="kontak-grid">
        {% for orang in collections.profil %}
        <div class="kontak-item">
          <span>{{ orang.data.nama }}</span>
          <a href="https://wa.me/62{{ orang.data.whatsapp | replace('0','',1) }}" target="_blank" rel="noopener">💬 WhatsApp</a>
        </div>
        {% endfor %}
      </div>

      <div class="info-divider"></div>
      <div class="info-lokasi">
        <span class="lbl">Lokasi</span>
        {{ site.info_lokasi }}
      </div>
    </div>
  </div>
</section>

<footer>
  {{ site.footer_teks }}
</footer>
